# Q2. Program to check whether a number is even or odd

# Ask the user to enter a number
num = int(input("Enter a number: "))   # input() returns string, so convert to int

# Check if the number is divisible by 2
if num % 2 == 0:   # condition True when remainder is 0
    print("Even Number")   # executes if number is divisible by 2
else:
    print("Odd Number")    # executes if number is not divisible by 2
